<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/imeRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/shinsoku_surface"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/imePanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_ime_surface"
        android:orientation="vertical"
        android:paddingLeft="8dp"
        android:paddingTop="6dp"
        android:paddingRight="8dp"
        android:paddingBottom="4dp">

        <LinearLayout
            android:id="@+id/imeKeyboardRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/imeLeftColumn"
                android:layout_width="64dp"
                android:layout_height="110dp"
                android:orientation="vertical">

                <Button
                    android:id="@+id/imeModeButton"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_ime_button_outline"
                    android:backgroundTint="@null"
                    android:elevation="0dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:paddingLeft="4dp"
                    android:paddingRight="4dp"
                    android:stateListAnimator="@null"
                    android:text="@string/ime_mode_button"
                    android:textAllCaps="false"
                    android:textColor="@color/shinsoku_text"
                    android:translationZ="0dp"
                    android:textSize="11sp" />

                <Button
                    android:id="@+id/imeMoreButton"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginTop="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_ime_button_outline"
                    android:backgroundTint="@null"
                    android:elevation="0dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:paddingLeft="4dp"
                    android:paddingRight="4dp"
                    android:stateListAnimator="@null"
                    android:text="@string/ime_more"
                    android:textAllCaps="false"
                    android:textColor="@color/shinsoku_text"
                    android:translationZ="0dp"
                    android:textSize="11sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/imeCenterColumn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="10dp"
                android:layout_marginRight="10dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <Button
                    android:id="@+id/micButton"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:background="@drawable/bg_ime_button_primary_pill"
                    android:backgroundTint="@null"
                    android:elevation="0dp"
                    android:minHeight="0dp"
                    android:paddingLeft="12dp"
                    android:paddingRight="12dp"
                    android:stateListAnimator="@null"
                    android:text="@string/ime_mic"
                    android:textAllCaps="false"
                    android:textColor="@color/shinsoku_on_primary"
                    android:translationZ="0dp"
                    android:textSize="15sp" />

                <Button
                    android:id="@+id/spaceButton"
                    android:layout_width="match_parent"
                    android:layout_height="38dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_ime_button_outline"
                    android:backgroundTint="@null"
                    android:elevation="0dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:stateListAnimator="@null"
                    android:text="@string/ime_space"
                    android:textAllCaps="false"
                    android:textColor="@color/shinsoku_text"
                    android:translationZ="0dp"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/imeRightColumn"
                android:layout_width="54dp"
                android:layout_height="110dp"
                android:orientation="vertical">

                <ImageButton
                    android:id="@+id/backspaceButton"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_ime_button_outline"
                    android:backgroundTint="@null"
                    android:contentDescription="@string/ime_delete"
                    android:elevation="0dp"
                    android:padding="10dp"
                    android:scaleType="center"
                    android:src="@drawable/ic_ime_backspace"
                    android:stateListAnimator="@null"
                    android:tint="@color/shinsoku_text"
                    android:translationZ="0dp" />

                <ImageButton
                    android:id="@+id/enterButton"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginTop="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_ime_button_outline"
                    android:backgroundTint="@null"
                    android:contentDescription="@string/ime_enter"
                    android:elevation="0dp"
                    android:padding="10dp"
                    android:scaleType="center"
                    android:src="@drawable/ic_ime_enter"
                    android:stateListAnimator="@null"
                    android:tint="@color/shinsoku_text"
                    android:translationZ="0dp" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/imeLivePreview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_ime_section_soft"
            android:gravity="center"
            android:minHeight="36dp"
            android:maxLines="2"
            android:paddingLeft="10dp"
            android:paddingTop="7dp"
            android:paddingRight="10dp"
            android:paddingBottom="7dp"
            android:text="@string/ime_live_preview_placeholder"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="@color/shinsoku_text"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/imePendingActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_ime_section_soft"
            android:orientation="vertical"
            android:padding="6dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/imePendingHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/ime_pending_hint"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:textColor="@color/shinsoku_text_muted" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/clearButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_ime_button_outline"
                    android:backgroundTint="@null"
                    android:elevation="0dp"
                    android:minHeight="30dp"
                    android:stateListAnimator="@null"
                    android:text="@string/ime_clear"
                    android:textAllCaps="false"
                    android:translationZ="0dp"
                    android:textColor="@color/shinsoku_text" />

                <Button
                    android:id="@+id/editButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_ime_button_outline"
                    android:backgroundTint="@null"
                    android:elevation="0dp"
                    android:minHeight="30dp"
                    android:stateListAnimator="@null"
                    android:text="@string/ime_edit"
                    android:textAllCaps="false"
                    android:translationZ="0dp"
                    android:textColor="@color/shinsoku_text" />

                <Button
                    android:id="@+id/insertButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_ime_button_tonal"
                    android:backgroundTint="@null"
                    android:elevation="0dp"
                    android:minHeight="30dp"
                    android:stateListAnimator="@null"
                    android:text="@string/ime_insert"
                    android:textAllCaps="false"
                    android:translationZ="0dp"
                    android:textColor="@color/shinsoku_text" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <View
        android:id="@+id/imeBottomBar"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@color/shinsoku_inverse_surface" />
</LinearLayout>
