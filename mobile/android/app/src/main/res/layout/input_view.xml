<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/imeRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="8dp">

    <LinearLayout
        android:id="@+id/imePanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_ime_surface"
        android:orientation="vertical"
        android:padding="18dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:contentDescription="@string/app_name"
                android:src="@drawable/ic_shinsoku_mark"
                app:tint="@color/shinsoku_text" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/imeTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/ime_title_idle"
                    android:textAppearance="?attr/textAppearanceTitleSmall"
                    android:textColor="@color/shinsoku_text"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/imeSubtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/ime_subtitle_ready"
                    android:textAppearance="?attr/textAppearanceLabelSmall"
                    android:textColor="@color/shinsoku_text_muted" />
            </LinearLayout>

            <Button
                android:id="@+id/imeMoreButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_ime_button_outline"
                android:minWidth="0dp"
                android:minHeight="40dp"
                android:paddingLeft="14dp"
                android:paddingTop="8dp"
                android:paddingRight="14dp"
                android:paddingBottom="8dp"
                android:text="@string/ime_more"
                android:textColor="@color/shinsoku_text" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:background="@drawable/bg_ime_section_soft"
            android:padding="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ime_mode_label"
                android:textAppearance="?attr/textAppearanceLabelMedium"
                android:textColor="@color/shinsoku_text_muted" />

            <Spinner
                android:id="@+id/imePresetSpinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_ime_button_outline"
                android:minHeight="40dp"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:spinnerMode="dropdown" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <Button
                android:id="@+id/micButton"
                android:layout_width="220dp"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_ime_button_primary_pill"
                android:minHeight="58dp"
                android:paddingLeft="20dp"
                android:paddingTop="12dp"
                android:paddingRight="20dp"
                android:paddingBottom="12dp"
                android:textSize="16sp"
                android:textColor="@color/shinsoku_on_primary"
                android:text="@string/ime_mic" />

            <TextView
                android:id="@+id/imeMicHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/ime_mic_hint"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:textColor="@color/shinsoku_text_muted" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/imePendingActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_ime_section_soft"
            android:orientation="vertical"
            android:padding="12dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/imePendingHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/ime_pending_hint"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:textColor="@color/shinsoku_text_muted" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/clearButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_ime_button_outline"
                    android:minHeight="40dp"
                    android:text="@string/ime_clear"
                    android:textColor="@color/shinsoku_text" />

                <Button
                    android:id="@+id/editButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_ime_button_outline"
                    android:minHeight="40dp"
                    android:text="@string/ime_edit"
                    android:textColor="@color/shinsoku_text" />

                <Button
                    android:id="@+id/insertButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_ime_button_tonal"
                    android:minHeight="40dp"
                    android:text="@string/ime_insert"
                    android:textColor="@color/shinsoku_text" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
