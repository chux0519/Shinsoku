<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_ime_surface"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:contentDescription="@string/app_name"
                android:src="@drawable/ic_shinsoku_mark"
                app:tint="@color/shinsoku_text" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/imeTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/ime_title_idle"
                    android:textAppearance="?attr/textAppearanceTitleMedium"
                    android:textColor="@color/shinsoku_text"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/imeSubtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/ime_subtitle_ready"
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:textColor="@color/shinsoku_text_muted" />
            </LinearLayout>

            <Button
                android:id="@+id/imeSettingsButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_ime_button_outline"
                android:minWidth="0dp"
                android:minHeight="40dp"
                android:paddingLeft="14dp"
                android:paddingTop="8dp"
                android:paddingRight="14dp"
                android:paddingBottom="8dp"
                android:text="@string/ime_settings" />
        </LinearLayout>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/imeDictationButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_ime_button_chip"
                    android:minHeight="36dp"
                    android:paddingLeft="14dp"
                    android:paddingTop="6dp"
                    android:paddingRight="14dp"
                    android:paddingBottom="6dp"
                    android:text="@string/ime_profile_dictation_short" />

                <Button
                    android:id="@+id/imeChatButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_ime_button_chip"
                    android:minHeight="36dp"
                    android:paddingLeft="14dp"
                    android:paddingTop="6dp"
                    android:paddingRight="14dp"
                    android:paddingBottom="6dp"
                    android:text="@string/ime_profile_chat_short" />

                <Button
                    android:id="@+id/imeReviewButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_ime_button_chip"
                    android:minHeight="36dp"
                    android:paddingLeft="14dp"
                    android:paddingTop="6dp"
                    android:paddingRight="14dp"
                    android:paddingBottom="6dp"
                    android:text="@string/ime_profile_review_short" />

                <Button
                    android:id="@+id/imeTranslateButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_ime_button_chip"
                    android:minHeight="36dp"
                    android:paddingLeft="14dp"
                    android:paddingTop="6dp"
                    android:paddingRight="14dp"
                    android:paddingBottom="6dp"
                    android:text="@string/ime_profile_translate_short" />
            </LinearLayout>
        </HorizontalScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <Button
                android:id="@+id/micButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_ime_button_primary"
                android:minHeight="44dp"
                android:textColor="@color/shinsoku_on_primary"
                android:text="@string/ime_mic" />

            <Button
                android:id="@+id/insertButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_ime_button_tonal"
                android:minHeight="40dp"
                android:text="@string/ime_insert"
                android:visibility="gone" />

            <Button
                android:id="@+id/clearButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_ime_button_outline"
                android:minHeight="40dp"
                android:text="@string/ime_clear"
                android:visibility="gone" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ime_tools_label"
                android:textAppearance="?attr/textAppearanceLabelMedium"
                android:textColor="@color/shinsoku_text_muted" />

            <Button
                android:id="@+id/spaceButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_ime_button_outline"
                android:minHeight="40dp"
                android:text="@string/ime_space" />

            <Button
                android:id="@+id/backspaceButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_ime_button_outline"
                android:minHeight="40dp"
                android:text="@string/ime_delete" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
