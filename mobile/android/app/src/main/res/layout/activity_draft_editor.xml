<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/shinsoku_bg"
    android:orientation="vertical"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_ime_surface"
        android:orientation="vertical"
        android:padding="18dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/draft_editor_title"
            android:textAppearance="?attr/textAppearanceHeadlineSmall"
            android:textColor="@color/shinsoku_text"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/draft_editor_subtitle"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="@color/shinsoku_text_muted" />

        <EditText
            android:id="@+id/draftEditorText"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="18dp"
            android:layout_weight="1"
            android:background="@drawable/bg_ime_section_soft"
            android:gravity="top|start"
            android:hint="@string/draft_editor_hint"
            android:inputType="textMultiLine|textCapSentences"
            android:minLines="8"
            android:padding="16dp"
            android:textColor="@color/shinsoku_text"
            android:textColorHint="@color/shinsoku_text_muted" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="end"
            android:orientation="horizontal">

            <Button
                android:id="@+id/draftCancelButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_ime_button_outline"
                android:minHeight="44dp"
                android:text="@string/draft_editor_cancel" />

            <Button
                android:id="@+id/draftInsertButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_ime_button_primary_pill"
                android:minHeight="44dp"
                android:paddingLeft="18dp"
                android:paddingRight="18dp"
                android:text="@string/draft_editor_insert"
                android:textColor="@color/shinsoku_on_primary" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
